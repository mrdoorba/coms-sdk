{
  "name": "@coms-portal/sdk",
  "version": "1.3.0",
  "description": "Framework-neutral SDK for COMS portal integrators",
  "type": "module",
  "license": "UNLICENSED",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/mrdoorba/coms-sdk.git"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./elysia": {
      "import": "./src/elysia.ts",
      "types": "./src/elysia.ts"
    },
    "./testing": {
      "import": "./src/testing/index.ts",
      "types": "./src/testing/index.ts"
    },
    "./constants/app-launcher": {
      "import": "./src/constants/app-launcher.ts",
      "types": "./src/constants/app-launcher.ts"
    }
  },
  "bin": {
    "coms-portal-cli": "./src/cli.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coms-portal/shared": "git+https://github.com/mrdoorba/coms-shared.git#v1.6.0",
    "jose": "^6"
  },
  "peerDependencies": {
    "elysia": "^1",
    "google-auth-library": "^9 || ^10"
  },
  "peerDependenciesMeta": {
    "elysia": {
      "optional": true
    },
    "google-auth-library": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "elysia": "^1",
    "google-auth-library": "^10",
    "typescript": "^5.9.3"
  }
}
